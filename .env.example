# webreel — Environment Variables
# Copy to .env and uncomment the variables you need.
# The CLI loads .env automatically via dotenv.

# ── TTS Providers (at least one required for narration) ──────────────
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...

# ── LLM Providers (for author/plan commands) ─────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=...
# TOGETHER_API_KEY=...

# ── Local TTS (Piper) ───────────────────────────────────────────────
# PIPER_PATH=/usr/local/bin/piper
# PIPER_MODEL_PATH=~/.local/share/piper/en_US-lessac-medium.onnx

# ── Binary overrides ────────────────────────────────────────────────
# CHROME_PATH=/usr/bin/google-chrome
# FFMPEG_PATH=/usr/local/bin/ffmpeg
